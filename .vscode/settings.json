// Place your settings in this file to overwrite default and user settings.
{
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "js/ts.preferences.quoteStyle": "double",
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "files.exclude": {
    "**/node_modules/": true,
    // "**/build/": true,
    // "**/Build/": true,
  },
  "files.watcherExclude": {
    "**/node_modules/": true,
    "**/build/": true,
    "**/Build/": true,
  },
  "cSpell.ignorePaths": [
    "node_modules",
    "**/node_modules",
    "**/node_modules/**",
    "node_modules/**",
    "vscode-extension",
    ".git",
    "CODE_OF_CONDUCT.md",
    "package-lock.json",
    "yarn.lock",
  ],
  "cSpell.words": [
    "argsx",
    "asyncly",
    "autorender",
    "autorun",
    "bayan",
    "Boocel",
    "cfalse",
    "contenteditable",
    "ctrue",
    "gastronom",
    "gost",
    "gvozdi",
    "Hoverable",
    "linkify",
    "mastak",
    "mpath",
    "Mvcc",
    "Nezaboodka",
    "noindex",
    "nothrow",
    "orangered",
    "prismjs",
    "proto",
    "reactronic",
    "relayout",
    "rescripting",
    "restyler",
    "Sctn",
    "sidebyside",
    "tektur",
    "treeshake",
    "verstak",
    "ychetyrko",
    "Yury"
  ]
}
